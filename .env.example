# ============================================================
# Legal RAG API — example environment configuration.
# Copy to ".env" and adjust.  All values are optional; the app
# runs with sensible defaults if this file is absent.
# ============================================================

# -- Server --
API_HOST=127.0.0.1          # use 0.0.0.0 to expose on the network
API_PORT=8000
API_DEBUG=false

# -- Auth --
# Set a strong secret to REQUIRE the "X-API-Key" header on /upload, /chat,
# /documents. Leave empty ONLY for local development.
API_KEY=

# -- CORS --
# Comma-separated allowed origins. Use "*" to allow all (credentials are
# then automatically disabled).
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# -- Uploads --
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50

# -- Embedding --
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DEVICE=cpu         # cpu | cuda | mps

# -- ChromaDB --
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION=legal_documents

# -- LLM (Ollama) --
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT=120

# -- RAG --
RAG_TOP_K=8
RAG_MAX_CONTEXT_CHARS=16000

# -- Audit log (KVKK) --
AUDIT_LOG_FILE=logs/access.log
